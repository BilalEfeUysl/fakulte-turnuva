{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Ana pencere izinleri",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "fs:default",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$PICTURE/**" },
        { "path": "$HOME/**" }
      ]
    }
  ]
}
